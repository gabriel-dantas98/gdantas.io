{
  "private": true,
  "name": "gdantas.dev",
  "version": "2.1.1",
  "description": "Personal Website for gdantas.dev",
  "repository": "https://github.com/gabriel-dantas98/gdantas.io",
  "author": "gdantasdev <me@gdantas.dev>",
  "license": "MIT",
  "packageManager": "yarn@3.2.0",
  "prettier": {
    "arrowParens": "always",
    "bracketSpacing": true,
    "jsxBracketSameLine": true,
    "printWidth": 100,
    "semi": true,
    "singleQuote": true,
    "tabWidth": 4,
    "trailingComma": "all",
    "useTabs": true
  },
  "scripts": {
    "analyze": "cross-env ANALYZE=true next build",
    "dev": "next",
    "build": "next build",
    "postbuild": "next-sitemap",
    "start": "next start",
    "export": "next build && next export",
    "ci": "bash scripts/ci.sh",
    "validate": "bash scripts/ci.sh",
    "lint": "next lint",
    "type-check": "tsc",
    "format": "prettier --write \"**/*.{css,js,json,jsx,ts,tsx,vue}\"",
    "i18n:check": "tsx scripts/i18n-check.ts",
    "sitemap:check": "NODE_ENV=production next-sitemap --config next-sitemap.js && tsx scripts/seo-indexing-check.ts",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:install": "playwright install --with-deps chromium"
  },
  "dependencies": {
    "@headlessui/react": "^1.4.1",
    "@hookstate/core": "^3.0.13",
    "@hookstate/persistence": "^3.0.0",
    "@iconify/react": "^3.0.1",
    "@remotion/player": "^4.0.464",
    "@splitbee/web": "^0.3.0",
    "canvas-confetti": "^1.4.0",
    "clsx": "^1.1.1",
    "copy-to-clipboard": "^3.3.1",
    "date-fns": "^2.24.0",
    "emoji-regex": "^10.1.0",
    "gsap": "3.12.5",
    "inter-ui": "^3.19.3",
    "is-web-crawler": "^1.1.0",
    "js-yaml": "^4.1.1",
    "motion": "^10.7.2",
    "next": "13",
    "next-axiom": "^0.13.0",
    "next-mdx-remote": "^3.0.6",
    "next-seo": "^4.28.1",
    "next-themes": "^0.1.1",
    "nprogress": "^0.2.0",
    "ogl-typescript": "^0.1.40",
    "posthog-js": "^1.373.5",
    "preact": "^10.10.0",
    "react": "18",
    "react-dom": "18",
    "react-hot-toast": "^2.1.1",
    "react-particles": "^2.3.3",
    "react-use": "^17.3.1",
    "react-use-lanyard": "^0.1.0",
    "rehype-autolink-headings": "^6.1.0",
    "remark-code-titles": "^0.1.2",
    "remark-emoji": "^3.0.1",
    "remark-prism": "^1.3.6",
    "remark-slug": "^7.0.0",
    "remotion": "^4.0.464",
    "rss-parser": "^3.13.0",
    "swr": "^1.0.1",
    "tsparticles": "^2.3.4",
    "use-sound": "^4.0.1",
    "web-vitals": "^5.1.0",
    "windicss": "^3.5.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/canvas-confetti": "^1.4.2",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^16.10.1",
    "@types/node-fetch": "^2.6.2",
    "@types/nprogress": "^0.2.0",
    "@types/react": "18",
    "@types/react-dom": "18",
    "eslint": "8.10.0",
    "eslint-config-next": "13",
    "gray-matter": "^4.0.3",
    "next-sitemap": "^2.5.4",
    "node-fetch": "^3.2.10",
    "prettier": "^2.4.1",
    "serve": "^14.2.6",
    "ts-shader-loader": "^1.0.6",
    "tsx": "^4.22.2",
    "typescript": "^4.4.3",
    "windicss-webpack-plugin": "^1.6.10"
  }
}
